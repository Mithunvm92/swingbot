# =============================================================================
# ZERODHA BROKER CONFIGURATION
# =============================================================================

# Required: API Key from https://developers.kite.trade
ZERODHA_API_KEY=

# Required: API Secret from https://developers.kite.trade
ZERODHA_API_SECRET=

# Auto-login settings (optional but recommended for automation)
# The user ID for your Zerodha account
ZERODHA_USER_ID=

# The password for your Zerodha account
ZERODHA_PASSWORD=

# TOTP Secret - Get from Kite settings > Security > Enable Two-Factor > Generate TOTP secret
# This is a 32-character Base32 string
ZERODHA_TOTP_SECRET=

# Enable auto-login on startup
ZERODHA_AUTO_LOGIN=false

# Debug mode (outputs more logging)
ZERODHA_DEBUG=false


# =============================================================================
# TRADING CONFIGURATION
# =============================================================================

# Trading mode: 'backtest' | 'paper' | 'live'
TRADING_MODE=paper

# Initial capital for trading (₹)
INITIAL_CAPITAL=100000

# Maximum capital per trade (₹)
MAX_CAPITAL_PER_TRADE=10000

# Risk per trade (percentage of capital)
RISK_PER_TRADE_PERCENT=1.0

# Maximum simultaneous trades
MAX_SIMULTANEOUS_TRADES=3

# Daily maximum loss (percentage of capital)
DAILY_MAX_LOSS_PERCENT=2.0

# Maximum consecutive losses before stopping
MAX_CONSECUTIVE_LOSSES=3

# Profit target (percentage)
PROFIT_TARGET_PERCENT=4.0

# Stop loss (percentage)
STOP_LOSS_PERCENT=2.0

# Trading cooldown between trades for same stock (minutes)
TRADING_COOLDOWN_MINUTES=15

# Scanner interval (minutes)
SCAN_INTERVAL_MINUTES=15

# Order type: CNC (Delivery) or MIS (Intraday)
ORDER_TYPE=CNC


# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database type: 'sqlite' | 'postgresql'
DATABASE_TYPE=sqlite

# SQLite (default)
# Data directory is created automatically

# PostgreSQL (optional - only if DATABASE_TYPE=postgresql)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=tradingbot
# POSTGRES_PASSWORD=
# POSTGRES_DB=tradingbot


# =============================================================================
# TELEGRAM ALERTS CONFIGURATION
# =============================================================================

# Enable Telegram alerts
ENABLE_TELEGRAM_ALERTS=true

# Get Bot Token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Get Chat ID from @userinfobot on Telegram
TELEGRAM_CHAT_ID=

# Enable specific alert types
ENABLE_BUY_SIGNALS=true
ENABLE_SELL_SIGNALS=true
ENABLE_ORDER_EXECUTIONS=true
ENABLE_DAILY_SUMMARY=true
ENABLE_ERRORS=true


# =============================================================================
# BACKTESTING CONFIGURATION
# =============================================================================

# Backtest date range
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2024-12-31

# Initial capital for backtesting
BACKTEST_INITIAL_CAPITAL=100000

# Commission per trade (percentage)
BACKTEST_COMMISSION=0.1

# Slippage (price impact, percentage)
BACKTEST_SLIPPAGE=0.05


# =============================================================================
# SCHEDULER CONFIGURATION
# =============================================================================

# Market hours (IST)
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=15
MARKET_CLOSE_HOUR=15
MARKET_CLOSE_MINUTE=30

# Timezone
TIMEZONE=Asia/Kolkata

# Auto login time (before market open)
AUTO_LOGIN_HOUR=8
AUTO_LOGIN_MINUTE=30


# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Enable console output
CONSOLE_OUTPUT=true